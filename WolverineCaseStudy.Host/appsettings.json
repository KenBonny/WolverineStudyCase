{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Wolverine": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "TimedApprovalSaga": {
    "Timeout": "00:02:00"
  },
  "ConnectionStrings": {
    "RabbitMQ": "amqp://guest:guest@localhost:5672",
    "NsbRabbitMQ": "amqp://guest:guest@localhost:5672/nsb",
    "TimedApprovalSagaDb": "Server=localhost;Port=5432;Database=timed_approval_saga;User Id=admin;Password=tracker-sauna-embarked-doomsday-sterling-greens;"
  }
}
